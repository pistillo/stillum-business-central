{
  "name": "@theia/ai-google",
  "version": "1.69.0",
  "description": "Theia - Google AI Integration",
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@theia/ai-core": "1.69.0",
    "@theia/core": "1.69.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/google-frontend-module",
      "backend": "lib/node/google-backend-module"
    }
  ],
  "keywords": [
    "theia-extension",
    "ai",
    "google",
    "gemini"
  ],
  "license": "EPL-2.0 OR GPL-2.0-only WITH Classpath-exception-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-theia/theia.git"
  },
  "bugs": {
    "url": "https://github.com/eclipse-theia/theia/issues"
  },
  "homepage": "https://github.com/eclipse-theia/theia",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npx theiaext build",
    "clean": "npx theiaext clean",
    "compile": "npx theiaext compile",
    "lint": "npx theiaext lint",
    "test": "npx theiaext test",
    "watch": "npx theiaext watch"
  },
  "devDependencies": {
    "@theia/ext-scripts": "1.69.0"
  },
  "nyc": {
    "extends": "../../configs/nyc.json"
  }
}
