{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/.*/**/*.ts",
    "src/**/.*/**/*.tsx",
    "src/**/.*/**/*.js",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    ".storybook/**/*.js",
    "*.js",
    "*.ts"
  ],
  "exclude": [
    "src/**/*.d.ts"
  ]
}
